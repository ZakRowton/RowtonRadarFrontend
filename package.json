{
  "name": "weather-radar-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-all.cjs",
    "dev:api": "node scripts/dev-api.cjs",
    "dev:web": "next dev",
    "dev:web:wait": "npx wait-on -t 120000 http-get://127.0.0.1:8000/radar/mesonet-tms && next dev",
    "dev:next": "next dev",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",

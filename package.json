    "@turf/boolean-intersects": "^7.3.5",
    "@turf/centroid": "^7.3.5",
    "@types/mapbox__vector-tile": "^1.3.4",
    "leaflet": "^1.9.4",
    "maplibre-gl": "^4.7.1",
    "next": "^14.2.26",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-draggable": "^4.5.0"
  },
  "devDependencies": {
